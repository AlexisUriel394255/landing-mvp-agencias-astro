---
import Layout from '../layouts/Layout.astro';
import RobotViewer from '../components/3D/RobotViewer.jsx';
---

<Layout title="Premium Web Development for High-Converting Agencies">
	<!-- Hero Section -->
	<section class="relative min-h-screen flex items-center bg-slate-950 text-slate-50 px-6 overflow-hidden">
		<div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
			
			<!-- Left: Value Proposition -->
			<div class="flex flex-col gap-6 max-w-xl">
				<span class="text-sm font-semibold tracking-wider text-emerald-400 uppercase">
					Exclusive for Digital Agencies
				</span>
				<h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight">
					Your Website is Slow. <br />
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">
						We Fix Your Sales.
					</span>
				</h1>
				<p class="text-lg text-slate-400 leading-relaxed">
					Don't let a bad PageSpeed score ruin your agency's reputation. We build ultra-fast, 100% score landing pages powered by Astro & headless architecture. 
				</p>
				<div class="flex flex-col sm:flex-row gap-4 mt-4">
					<a href="#contact" class="px-8 py-4 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold rounded-lg transition-all text-center shadow-lg shadow-emerald-500/20">
						Book a 15-Min Speed Audit
					</a>
					<a href="#features" class="px-8 py-4 bg-slate-900 border border-slate-800 hover:bg-slate-800 font-semibold rounded-lg transition-all text-center">
						See Stack & Proof
					</a>
				</div>
			</div>

			<!-- Right: 3D Robot Container -->
			<div class="relative w-full h-[450px] lg:h-[600px] flex items-center justify-center">
				<div class="absolute w-72 h-72 bg-emerald-500/10 rounded-full blur-3xl"></div>
				
				<!-- Cambio estratégico: client:only obliga a Astro a no interferir con Spline en el servidor -->
				<RobotViewer client:only="react" />
			</div>

		</div>
	</section>

	<!-- Problem/Agitation Section -->
	<section id="features" class="py-24 bg-slate-900 text-slate-50 px-6">
		<div class="max-w-5xl mx-auto text-center flex flex-col gap-4">
			<h2 class="text-3xl md:text-4xl font-bold tracking-tight">
				Why a Red PageSpeed Score Kills Your Deals
			</h2>
			<p class="text-slate-400 max-w-2xl mx-auto">
				When a CEO or Tech Leader visits your agency site and experiences lag, you lose authority instantly.
			</p>
		</div>
		<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
			<div class="p-8 bg-slate-950 border border-slate-800 rounded-xl flex flex-col gap-4">
				<div class="text-emerald-400 text-2xl font-bold">100% Score</div>
				<h3 class="text-xl font-bold">Blazing Fast SSG</h3>
				<p class="text-slate-400 text-sm leading-relaxed">Zero client-side JavaScript by default using Astro. Maximum core web vitals performance.</p>
			</div>
			<div class="p-8 bg-slate-950 border border-slate-800 rounded-xl flex flex-col gap-4">
				<div class="text-emerald-400 text-2xl font-bold">Premium UI</div>
				<h3 class="text-xl font-bold">Fluid Animations</h3>
				<p class="text-slate-400 text-sm leading-relaxed">Interactive 3D models and tailored Tailwind CSS styles without harming performance metrics.</p>
			</div>
			<div class="p-8 bg-slate-950 border border-slate-800 rounded-xl flex flex-col gap-4">
				<div class="text-emerald-400 text-2xl font-bold">Git CMS</div>
				<h3 class="text-xl font-bold">Full Autoadministrable</h3>
				<p class="text-slate-400 text-sm leading-relaxed">Lightweight headless CMS setup. Your client or team updates content directly via GitHub metadata.</p>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="py-24 bg-slate-950 text-slate-50 px-6 border-t border-slate-900">
		<div class="max-w-3xl mx-auto text-center flex flex-col gap-6">
			<h2 class="text-3xl md:text-5xl font-black tracking-tight">Ready to Elevate Your Performance?</h2>
			<p class="text-slate-400 text-lg">
				Let's deploy a tailored MVP for your team. Fixed price. 50% upfront. Delivered in days.
			</p>
			<div class="mt-8">
				<form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
					<input type="email" placeholder="Enter your business email" required class="px-4 py-3 bg-slate-900 border border-slate-800 rounded-lg focus:outline-none focus:border-emerald-500 flex-grow text-slate-100" />
					<button type="submit" class="px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold rounded-lg transition-all whitespace-nowrap">
						Get Started
					</button>
				</form>
			</div>
		</div>
	</section>
</Layout>
