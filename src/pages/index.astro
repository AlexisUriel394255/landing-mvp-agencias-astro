---
export const prerender = true; // Sostiene la velocidad estática instantánea que te dio el 100
import Layout from '../layouts/Layout.astro';
import RobotViewer from '../components/3D/RobotViewer.jsx';
import { createClient } from '@sanity/client';

// Conexión limpia y directa al cliente de Sanity
const client = createClient({
  projectId: 'rgu9dc3a',
  dataset: 'production',
  useCdn: false, // 👈 ¡CAMBIA ESTO A FALSE! Obliga a leer datos frescos al compilar
  apiVersion: '2026-03-12',
});


// Consulta nativa ejecutada durante la compilación estática
const cmsDataArray = await client.fetch(`*[_type == "landingContent"]`);
const cms = cmsDataArray || {};

// Mapeo estricto al objeto de traducciones para alimentar el script cliente
const translations = {
  en: {
    hero_badge: cms.hero_badge_en || "Exclusive for Digital Agencies",
    hero_title_1: cms.hero_title_1_en || "Your Website is Slow.",
    hero_title_2: cms.hero_title_2_en || "We Fix Your Sales.",
    hero_desc: cms.hero_desc_en || "Don't let a bad PageSpeed score ruin your agency's reputation. We build ultra-fast, 100% score landing pages powered by Astro & headless architecture.",
    hero_btn_audit: cms.hero_btn_audit_en || "Book a 15-Min Speed Audit",
    hero_btn_proof: cms.hero_btn_proof_en || "See Stack & Proof",
    features_heading: cms.features_heading_en || "Why a Red PageSpeed Score Kills Your Deals",
    features_subheading: cms.features_subheading_en || "When a CEO or Tech Leader visits your agency site and experiences lag, you lose authority instantly.",
    feat_1_metric: cms.feat_1_metric_en || "100% Score",
    feat_1_title: cms.feat_1_title_en || "Blazing Fast SSG",
    feat_1_desc: cms.feat_1_desc_en || "Zero client-side JavaScript by default using Astro. Maximum core web vitals performance.",
    feat_2_metric: cms.feat_2_metric_en || "Premium UI",
    feat_2_title: cms.feat_2_title_en || "Fluid Animations",
    feat_2_desc: cms.feat_2_desc_en || "Interactive 3D models and tailored Tailwind CSS styles without harming performance metrics.",
    feat_3_metric: cms.feat_3_metric_en || "Git CMS",
    feat_3_title: cms.feat_3_title_en || "Full Autoadministrable",
    feat_3_desc: cms.feat_3_desc_en || "Lightweight headless CMS setup. Your client or team updates content directly via GitHub metadata.",
    contact_heading: cms.contact_heading_en || "Ready to Elevate Your Performance?",
    contact_subheading: cms.contact_subheading_en || "Let's deploy a tailored MVP for your team. Fixed price. 50% upfront. Delivered in days.",
    contact_btn: cms.contact_btn_en || "Get Started",
    contact_placeholder: cms.contact_placeholder_en || "Enter your business email",
    form_sending: "Sending...",
    form_success: "🚀 Awesome! Check your inbox shortly.",
    form_error_domain: "❌ Please use a business email (no Gmail/Yahoo).",
    form_error_server: "❌ Something went wrong. Try again."
  },
  es: {
    hero_badge: cms.hero_badge_es || "Exclusivo para Agencias Digitales",
    hero_title_1: cms.hero_title_1_es || "Tu Web es Lenta.",
    hero_title_2: cms.hero_title_2_es || "Nosotros Reparamos tus Ventas.",
    hero_desc: cms.hero_desc_es || "No dejes que una mala puntuación de PageSpeed arruine la reputación de tu agencia. Construimos páginas ultra rápidas.",
    hero_btn_audit: cms.hero_btn_audit_es || "Reserva una Auditoría de 15 Min",
    hero_btn_proof: cms.hero_btn_proof_es || "Ver Stack y Pruebas",
    features_heading: cms.features_heading_es || "Por qué un PageSpeed en Rojo Mata tus Tratos",
    features_subheading: cms.features_subheading_es || "Cuando un CEO o Líder Técnico visita tu sitio y experimenta lentitud, pierdes autoridad instantáneamente.",
    feat_1_metric: cms.feat_1_metric_es || "Score de 100%",
    feat_1_title: cms.feat_1_title_es || "SSG Ultra Rápido",
    feat_1_desc: cms.feat_1_desc_es || "Cero JavaScript del lado del cliente por defecto usando Astro.",
    feat_2_metric: cms.feat_2_metric_es || "UI Premium",
    feat_2_title: cms.feat_2_title_es || "Animaciones Fluidas",
    feat_2_desc: cms.feat_2_desc_es || "Modelos 3D interactivos y estilos Tailwind CSS a medida.",
    feat_3_metric: cms.feat_3_metric_es || "Git CMS",
    feat_3_title: cms.feat_3_title_es || "Auto-administrable",
    feat_3_desc: cms.feat_3_es || "CMS headless ligero. Tu equipo actualiza contenido directamente.",
    contact_heading: cms.contact_heading_es || "¿Listo para Elevar tu Rendimiento?",
    contact_subheading: cms.contact_subheading_es || "Despleguemos un MVP a la medida de tu equipo.",
    contact_btn: cms.contact_btn_es || "Comenzar",
    contact_placeholder: cms.contact_placeholder_es || "Ingresa tu correo empresarial",
    form_sending: "Enviando...",
    form_success: "🚀 ¡Excelente! Revisa tu bandeja de entrada pronto.",
    form_error_domain: "❌ Por favor usa un correo empresarial (no Gmail/Yahoo).",
    form_error_server: "❌ Algo salió mal. Inténtalo de nuevo."
  }
};
---
<Layout title="Premium Web Development for High-Converting Agencies">
  <!-- Hero Section con posicionamiento relativo -->
  <section class="relative min-h-screen flex items-center bg-slate-950 text-slate-50 px-6 overflow-hidden">
    <div class="absolute top-6 left-0 w-screen z-50 pointer-events-none">
      <div class="absolute right-4 md:right-6 lg:right-8 bg-slate-900/90 backdrop-blur-md border border-slate-800 px-3 py-1.5 rounded-full flex items-center gap-1 shadow-2xl transition-all hover:border-slate-700 pointer-events-auto">
        <button id="btn-en" class="text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer bg-emerald-500 text-slate-950 select-none">EN</button>
        <button id="btn-es" class="text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer text-slate-400 hover:text-white select-none">ES</button>
      </div>
    </div>

    <!-- Grid Limpio al Ancho Máximo Estándar -->
    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
      <!-- Left: Value Proposition -->
      <div class="flex flex-col gap-6 max-w-xl">
        <span class="text-sm font-semibold tracking-wider text-emerald-400 uppercase" data-i18n="hero_badge">{translations.en.hero_badge}</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight">
          <span data-i18n="hero_title_1">{translations.en.hero_title_1}</span> <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500" data-i18n="hero_title_2">{translations.en.hero_title_2}</span>
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed" data-i18n="hero_desc">{translations.en.hero_desc}</p>
        
        <div class="flex flex-col sm:flex-row gap-4 mt-4 items-stretch sm:items-center w-full">
          <a href="#contact" class="flex items-center justify-center px-4 md:px-5 py-4 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold rounded-lg transition-all text-center shadow-lg shadow-emerald-500/20 text-sm md:text-base whitespace-nowrap min-h-[56px] flex-1 sm:flex-initial" data-i18n="hero_btn_audit">{translations.en.hero_btn_audit}</a>
          <a href="#features" class="flex items-center justify-center px-4 md:px-5 py-4 bg-slate-900 border border-slate-800 hover:bg-slate-800 font-semibold rounded-lg transition-all text-center text-sm md:text-base whitespace-nowrap min-h-[56px] flex-1 sm:flex-initial" data-i18n="hero_btn_proof">{translations.en.hero_btn_proof}</a>
        </div>
      </div>

      <!-- Right: Contenedor Rediseñado Limpio -->
      <div class="relative w-full aspect-square max-w-[500px] lg:max-w-none mx-auto flex items-center justify-center">
        <div class="absolute inset-0 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
        
        <!-- ==================== BLOQUE DE ESCRITORIO STABLE ==================== -->
        <div class="w-full h-full relative hidden lg:block min-h-[400px] lg:min-h-[600px]">
          <div id="desktop-facade" class="absolute inset-0 z-20 transition-opacity duration-500 ease-out pointer-events-none">
            <img src="/images/robot-facade.webp" alt="Robot Render Facade" class="w-full h-full object-contain" fetchpriority="high" loading="eager" decoding="async" />
          </div>
          <!-- CORRECCIÓN OPTIMIZADA: client:only="react" para asegurar inmunidad frente a bots de Google -->
          <div id="desktop-interactive" class="absolute inset-0 z-10 opacity-0 transition-opacity duration-700 ease-in">
            <RobotViewer client:only="react" />
          </div>
        </div>

        <!-- ==================== BLOQUE DE MÓVIL ==================== -->
        <div class="w-full h-full relative block lg:hidden">
          <div id="mobile-facade" class="absolute inset-0 z-20 transition-opacity duration-500 ease-out">
            <img src="/images/video-mobile-facade.webp" alt="Video Preview Facade" class="w-full h-full object-cover rounded-2xl" fetchpriority="high" loading="eager" decoding="async" />
          </div>
          <video id="mobile-video" class="w-full h-full object-cover absolute inset-0 z-10 rounded-2xl" muted playsinline loop preload="none">
            <source src="/videos/robot-demo-mobile.webm" type="video/webm" />
          </video>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-24 bg-slate-900 text-slate-50 px-6">
    <div class="max-w-5xl mx-auto text-center flex flex-col gap-4">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight" data-i18n="features_heading">{translations.en.features_heading}</h2>
      <p class="text-slate-400 max-w-2xl mx-auto" data-i18n="features_subheading">{translations.en.features_subheading}</p>
    </div>
    
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
      <div class="p-8 bg-slate-950 border border-slate-800 rounded-xl flex flex-col gap-4">
        <div class="text-emerald-400 text-2xl font-bold" data-i18n="feat_1_metric">{translations.en.feat_1_metric}</div>
        <h3 class="text-xl font-bold" data-i18n="feat_1_title">{translations.en.feat_1_title}</h3>
        <p class="text-slate-400 text-sm leading-relaxed" data-i18n="feat_1_desc">{translations.en.feat_1_desc}</p>
      </div>
      <div class="p-8 bg-slate-950 border border-slate-800 rounded-xl flex flex-col gap-4">
        <div class="text-emerald-400 text-2xl font-bold" data-i18n="feat_2_metric">{translations.en.feat_2_metric}</div>
        <h3 class="text-xl font-bold" data-i18n="feat_2_title">{translations.en.feat_2_title}</h3>
        <p class="text-slate-400 text-sm leading-relaxed" data-i18n="feat_2_desc">{translations.en.feat_2_desc}</p>
      </div>
      <div class="p-8 bg-slate-950 border border-slate-800 rounded-xl flex flex-col gap-4">
        <div class="text-emerald-400 text-2xl font-bold" data-i18n="feat_3_metric">{translations.en.feat_3_metric}</div>
        <h3 class="text-xl font-bold" data-i18n="feat_3_title">{translations.en.feat_3_title}</h3>
        <p class="text-slate-400 text-sm leading-relaxed" data-i18n="feat_3_desc">{translations.en.feat_3_desc}</p>
      </div>
    </div>
  </section>

  <section id="contact" class="py-24 bg-slate-950 text-slate-50 px-6 border-t border-slate-900">
    <div class="max-w-3xl mx-auto text-center flex flex-col gap-6">
      <h2 class="text-3xl md:text-5xl font-black tracking-tight" data-i18n="contact_heading">{translations.en.contact_heading}</h2>
      <p class="text-slate-400 text-lg" data-i18n="contact_subheading">{translations.en.contact_subheading}</p>
      
      <div class="mt-8">
        <form id="lead-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto relative">
          <input type="email" placeholder={translations.en.contact_placeholder} required class="px-4 py-3 bg-slate-900 border border-slate-800 rounded-lg focus:outline-none focus:border-emerald-500 flex-grow text-slate-100 transition-colors" id="contact-email" />
          <button id="submit-btn" type="submit" class="px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold rounded-lg transition-all whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed" data-i18n="contact_btn">{translations.en.contact_btn}</button>
        </form>
        <div id="form-feedback" class="mt-4 text-sm font-semibold text-center hidden animate-fade-in"></div>
      </div>
    </div>
  </section>
</Layout>
<script define:vars={{ translations }} is:inline>
  // --- MÓDULO 1: MANEJO DE IDIOMA EN CLIENTE ---
  let currentLang = localStorage.getItem('preferred-lang') || 'en';
  
  function updateLanguage(lang) {
    currentLang = lang;
    document.querySelectorAll('[data-i18n]').forEach((element) => {
      const key = element.getAttribute('data-i18n');
      if (key && translations[lang] && translations[lang][key]) { 
        element.textContent = translations[lang][key]; 
      }
    });
    
    const emailInput = document.getElementById('contact-email');
    if (emailInput && translations[lang] && translations[lang].contact_placeholder) {
      emailInput.placeholder = translations[lang].contact_placeholder; 
    }
    
    const btnEn = document.getElementById('btn-en');
    const btnEs = document.getElementById('btn-es');
    if (btnEn && btnEs) {
      if (lang === 'en') {
        btnEn.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer bg-emerald-500 text-slate-950 select-none";
        btnEs.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer text-slate-400 hover:text-white select-none";
      } else {
        btnEs.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer bg-emerald-500 text-slate-950 select-none";
        btnEn.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer text-slate-400 hover:text-white select-none";
      }
    }
    localStorage.setItem('preferred-lang', lang);
  }

  updateLanguage(currentLang);
  document.getElementById('btn-en')?.addEventListener('click', () => updateLanguage('en'));
  document.getElementById('btn-es')?.addEventListener('click', () => updateLanguage('es'));

  // --- MÓDULO 2: INTERCEPCIÓN B2B Y ENVÍO A WEBHOOK CORREGIDO ---
  const leadForm = document.getElementById('lead-form');
  const emailInput = document.getElementById('contact-email');
  const submitBtn = document.getElementById('submit-btn');
  const feedback = document.getElementById('form-feedback');
  const blacklistedDomains = ['gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', 'live.com', 'icloud.com'];

  leadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!feedback || !submitBtn || !emailInput) return;
    
    feedback.className = "mt-4 text-sm font-semibold text-center hidden";
    
    const cleanEmail = emailInput.value.trim().toLowerCase();
    const parts = cleanEmail.split('@');
    const domain = parts[1]; // <-- CORREGIDO: Acceso al dominio real en el índice 1 del array
    
    if (blacklistedDomains.includes(domain)) {
      feedback.textContent = translations[currentLang].form_error_domain;
      feedback.className = "mt-4 text-sm font-semibold text-center text-rose-400";
      return;
    }
    
    submitBtn.disabled = true;
    const originalBtnText = submitBtn.textContent;
    submitBtn.textContent = translations[currentLang].form_sending;
    
    try {
      const response = await fetch('https://make.com', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          email: cleanEmail, 
          lang: currentLang, 
          source: 'agency_landing_mvp', 
          timestamp: new Date().toISOString() 
        })
      });
      
      if (response.ok) {
        feedback.textContent = translations[currentLang].form_success;
        feedback.className = "mt-4 text-sm font-semibold text-center text-emerald-400";
        leadForm.reset();
      } else { 
        throw new Error('Server error'); 
      }
    } catch (error) {
      feedback.textContent = translations[currentLang].form_error_server;
      feedback.className = "mt-4 text-sm font-semibold text-center text-rose-400";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalBtnText;
    }
  });
  // --- MÓDULO 3: INTEGRACIÓN PASIVA MULTIPANTALLA (100/100 VERIFICADO) ---
  function orchestrateFacades() {
    const dFacade = document.getElementById('desktop-facade');
    const dInteractive = document.getElementById('desktop-interactive');
    const mFacade = document.getElementById('mobile-facade');
    const mVideo = document.getElementById('mobile-video');
    const isDesktop = window.innerWidth >= 1024; // CORRECCIÓN: Breakpoint emparejado con 'lg' de Tailwind (1024px)

    // --- CONTROL PARA ESCRITORIO (PC) ---
    if (dFacade && dInteractive && isDesktop) {
      let pcLoaded = false;
      const loadPCSystem = () => {
        if (pcLoaded) return;
        pcLoaded = true;
        
        window.removeEventListener('mousemove', loadPCSystem);
        window.removeEventListener('scroll', loadPCSystem);
        window.removeEventListener('touchstart', loadPCSystem);
        
        // 1. Emitir evento para activar el renderizado diferido en React
        window.dispatchEvent(new CustomEvent('init-3d-scene'));
        
        // 2. Transición visual limpia de opacidades sin alterar el layout estructural
        setTimeout(() => {
          dInteractive.classList.remove('opacity-0');
          dFacade.classList.add('opacity-0');
          setTimeout(() => dFacade.style.display = 'none', 600);
        }, 300);
      };
      
      window.addEventListener('mousemove', loadPCSystem, { passive: true });
      window.addEventListener('scroll', loadPCSystem, { passive: true });
      window.addEventListener('touchstart', loadPCSystem, { passive: true });
    }

    // --- CONTROL PARA MÓVIL (ANDROID / IOS) ---
    if (mFacade && mVideo && !isDesktop) {
      let mobileLoaded = false;
      const loadMobileSystem = () => {
        if (mobileLoaded) return;
        mobileLoaded = true;
        
        window.removeEventListener('scroll', loadMobileSystem);
        window.removeEventListener('touchstart', loadMobileSystem);
        
        mVideo.preload = "auto";
        mVideo.play().then(() => {
          mFacade.classList.add('opacity-0');
          setTimeout(() => mFacade.style.display = 'none', 500);
        }).catch((err) => console.warn("Autoplay block:", err));
      };
      
      window.addEventListener('scroll', loadMobileSystem, { passive: true });
      window.addEventListener('touchstart', loadMobileSystem, { passive: true });
    }
  }

  // CORRECCIÓN MÁXIMA DE RENDIMIENTO: Evita duplicar listeners infinitamente tras swaps de Astro
  if (!window.__facadesOrchestrated) {
    if (document.readyState === 'complete') { 
      orchestrateFacades(); 
    } else { 
      window.addEventListener('DOMContentLoaded', orchestrateFacades, { once: true });
    }
    document.addEventListener('astro:after-swap', orchestrateFacades);
    window.__facadesOrchestrated = true;
  }
</script>
