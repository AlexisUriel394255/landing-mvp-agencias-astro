import { useState, useEffect } from 'react';
import Spline from '@splinetool/react-spline';

export default function RobotViewer() {
  const [shouldLoadSpline, setShouldLoadSpline] = useState(false);

  useEffect(() => {
    // Escuchamos eventos reales del usuario para activar el 3D en computadoras
    const triggerInteraction = () => {
      setShouldLoadSpline(true);
      cleanUpEvents();
    };

    const cleanUpEvents = () => {
      window.removeEventListener('mousemove', triggerInteraction);
      window.removeEventListener('scroll', triggerInteraction);
      window.removeEventListener('keydown', triggerInteraction);
      window.removeEventListener('touchstart', triggerInteraction);
    };

    window.addEventListener('mousemove', triggerInteraction, { passive: true });
    window.addEventListener('scroll', triggerInteraction, { passive: true });
    window.addEventListener('keydown', triggerInteraction, { passive: true });
    window.addEventListener('touchstart', triggerInteraction, { passive: true });

    return () => cleanUpEvents();
  }, []);

  return (
    <div className="relative w-full h-[400px] sm:h-[450px] lg:h-[600px] flex items-center justify-center overflow-hidden rounded-2xl bg-slate-900/40 border border-slate-800/50 backdrop-blur-sm z-10 px-4 md:px-0">
      
      {/* El canvas solo consume recursos si el usuario interactúa con la página */}
      <div className="w-full h-full">
        {shouldLoadSpline ? (
          <Spline 
            scene="https://spline.design" 
          />
        ) : (
          <div className="w-full h-full bg-transparent" />
        )}
      </div>

    </div>
  );
}
<script define:vars={{ translations }} is:inline>
  // --- MÓDULO 1: MANEJO DE IDIOMA EN CLIENTE ---
  let currentLang = localStorage.getItem('preferred-lang') || 'en';

  function updateLanguage(lang) {
    currentLang = lang;
    document.querySelectorAll('[data-i18n]').forEach((element) => {
      const key = element.getAttribute('data-i18n');
      if (key && translations[lang] && translations[lang][key]) {
        element.textContent = translations[lang][key];
      }
    });

    const emailInput = document.getElementById('contact-email');
    if (emailInput && translations[lang] && translations[lang].contact_placeholder) {
      emailInput.placeholder = translations[lang].contact_placeholder;
    }

    const btnEn = document.getElementById('btn-en');
    const btnEs = document.getElementById('btn-es');
    if (btnEn && btnEs) {
      if (lang === 'en') {
        btnEn.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer bg-emerald-500 text-slate-950 select-none";
        btnEs.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer text-slate-400 hover:text-white select-none";
      } else {
        btnEs.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer bg-emerald-500 text-slate-950 select-none";
        btnEn.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer text-slate-400 hover:text-white select-none";
      }
    }
    localStorage.setItem('preferred-lang', lang);
  }

  updateLanguage(currentLang);
  document.getElementById('btn-en')?.addEventListener('click', () => updateLanguage('en'));
  document.getElementById('btn-es')?.addEventListener('click', () => updateLanguage('es'));

  // --- MÓDULO 2: INTERCEPCIÓN B2B Y ENVÍO A WEBHOOK ---
  const leadForm = document.getElementById('lead-form');
  const emailInput = document.getElementById('contact-email');
  const submitBtn = document.getElementById('submit-btn');
  const feedback = document.getElementById('form-feedback');
  const blacklistedDomains = ['gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', 'live.com', 'icloud.com'];

  leadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!feedback || !submitBtn || !emailInput) return;

    feedback.classList.add('hidden');
    feedback.className = "mt-4 text-sm font-semibold text-center";

    const cleanEmail = emailInput.value.trim().toLowerCase();
    const domain = cleanEmail.split('@');

    if (blacklistedDomains.includes(domain)) {
      feedback.textContent = translations[currentLang].form_error_domain;
      feedback.classList.remove('hidden');
      feedback.classList.add('text-rose-400');
      return;
    }

    submitBtn.disabled = true;
    const originalBtnText = submitBtn.textContent;
    submitBtn.textContent = translations[currentLang].form_sending;

    try {
      const WEBHOOK_URL = 'https://make.com';
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: cleanEmail,
          lang: currentLang,
          source: 'agency_landing_mvp',
          timestamp: new Date().toISOString()
        })
      });

      if (response.ok) {
        feedback.textContent = translations[currentLang].form_success;
        feedback.classList.add('text-emerald-400');
        leadForm.reset();
      } else {
        throw new Error('Server response error');
      }
    } catch (error) {
      feedback.textContent = translations[currentLang].form_error_server;
      feedback.classList.add('text-rose-400');
    } finally {
      feedback.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = originalBtnText;
    }
  });

  // --- MÓDULO 3: ORQUESTADOR DE FACHADAS EQUILIBRADO POR ENTRADA ---
  function orchestrateFacades() {
    const dFacade = document.getElementById('desktop-facade');
    const dInteractive = document.getElementById('desktop-interactive');
    const mFacade = document.getElementById('mobile-facade');
    const mVideo = document.getElementById('mobile-video');

    const isDesktop = window.innerWidth >= 640;

    // Ejecución si es PC
    if (dFacade && dInteractive && isDesktop) {
      const swapDesktop = () => {
        // Reducido a 1.5s: Al estar condicionado a la interacción, la CPU inicial está en 0ms
        setTimeout(() => {
          if (dInteractive && dFacade) {
            dInteractive.classList.remove('opacity-0');
            dFacade.classList.add('opacity-0');
            setTimeout(() => dFacade.remove(), 500);
          }
        }, 1500);
      };

      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(swapDesktop);
      } else {
        window.addEventListener('load', swapDesktop);
      }
    }

    // Ejecución si es Celular
    if (mFacade && mVideo && !isDesktop) {
      const swapMobile = () => {
        setTimeout(() => {
          if (mVideo && mFacade) {
            mVideo.preload = "auto";
            mVideo.play().then(() => {
              mFacade.classList.add('opacity-0');
              setTimeout(() => mFacade.remove(), 500);
            }).catch((err) => {
              console.warn("Autoplay blocked on mobile, keeping facade active.", err);
            });
          }
        }, 0);
      };

      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(swapMobile);
      } else {
        window.addEventListener('load', swapMobile);
      }
    }
  }

  orchestrateFacades();
  document.addEventListener('astro:after-swap', orchestrateFacades);
</script>
