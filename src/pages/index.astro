---
import Layout from '../layouts/Layout.astro';
import RobotViewer from '../components/3D/RobotViewer.jsx';
import translations from '../data/translations.json';
---

<Layout title="Premium Web Development for High-Converting Agencies">
	<!-- Hero Section con posicionamiento relativo -->
	<section class="relative min-h-screen flex items-center bg-slate-950 text-slate-50 px-6 overflow-hidden">
		
		<!-- Contenedor invisible que mide el 100% del ancho de la pantalla -->
		<div class="absolute top-6 left-0 w-screen z-50 pointer-events-none">
			<!-- Botones posicionados al extremo derecho absoluto con margen mínimo al scrollbar -->
			<div class="absolute right-4 md:right-6 lg:right-8 bg-slate-900/90 backdrop-blur-md border border-slate-800 px-3 py-1.5 rounded-full flex items-center gap-1 shadow-2xl transition-all hover:border-slate-700 pointer-events-auto">
				<button id="btn-en" class="text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer bg-emerald-500 text-slate-950 select-none">
					EN
				</button>
				<button id="btn-es" class="text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer text-slate-400 hover:text-white select-none">
					ES
				</button>
			</div>
		</div>

		<!-- Grid Limpio al Ancho Máximo Estándar -->
		<div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
			
			<!-- Left: Value Proposition -->
			<div class="flex flex-col gap-6 max-w-xl">
				<span class="text-sm font-semibold tracking-wider text-emerald-400 uppercase" data-i18n="hero_badge">
					Exclusive for Digital Agencies
				</span>
				<h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight">
					<span data-i18n="hero_title_1">Your Website is Slow.</span> <br />
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500" data-i18n="hero_title_2">
						We Fix Your Sales.
					</span>
				</h1>
				<p class="text-lg text-slate-400 leading-relaxed" data-i18n="hero_desc">
					Don't let a bad PageSpeed score ruin your agency's reputation. We build ultra-fast, 100% score landing pages powered by Astro & headless architecture. 
				</p>
				<!-- Contenedor balanceado y con tamaño responsivo impecable -->
				<div class="flex flex-col sm:flex-row gap-4 mt-4 items-stretch sm:items-center w-full">
					<a href="#contact" class="flex items-center justify-center px-4 md:px-5 py-4 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold rounded-lg transition-all text-center shadow-lg shadow-emerald-500/20 text-sm md:text-base whitespace-nowrap min-h-[56px] flex-1 sm:flex-initial" data-i18n="hero_btn_audit">
						Book a 15-Min Speed Audit
					</a>
					<a href="#features" class="flex items-center justify-center px-4 md:px-5 py-4 bg-slate-900 border border-slate-800 hover:bg-slate-800 font-semibold rounded-lg transition-all text-center text-sm md:text-base whitespace-nowrap min-h-[56px] flex-1 sm:flex-initial" data-i18n="hero_btn_proof">
						See Stack & Proof
					</a>
				</div>
			</div>

			<!-- Right: Contenedor Cuadrado Perfecto con Relación de Aspecto Proporcional para Spline -->
			<div class="relative w-full aspect-square max-w-[500px] lg:max-w-none mx-auto flex items-center justify-center">
				<!-- Brillo de fondo escalado -->
				<div class="absolute inset-0 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
				<RobotViewer client:only="react" />
			</div>

		</div>
	</section>

	<!-- Problem/Agitation Section -->
	<section id="features" class="py-24 bg-slate-900 text-slate-50 px-6">
		<div class="max-w-5xl mx-auto text-center flex flex-col gap-4">
			<h2 class="text-3xl md:text-4xl font-bold tracking-tight" data-i18n="features_heading">
				Why a Red PageSpeed Score Kills Your Deals
			</h2>
			<p class="text-slate-400 max-w-2xl mx-auto" data-i18n="features_subheading">
				When a CEO or Tech Leader visits your agency site and experiences lag, you lose authority instantly.
			</p>
		</div>
		<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
			<!-- Feature 1 -->
			<div class="p-8 bg-slate-950 border border-slate-800 rounded-xl flex flex-col gap-4">
				<div class="text-emerald-400 text-2xl font-bold" data-i18n="feat_1_metric">100% Score</div>
				<h3 class="text-xl font-bold" data-i18n="feat_1_title">Blazing Fast SSG</h3>
				<p class="text-slate-400 text-sm leading-relaxed" data-i18n="feat_1_desc">Zero client-side JavaScript by default using Astro. Maximum core web vitals performance.</p>
			</div>
			<!-- Feature 2 -->
			<div class="p-8 bg-slate-950 border border-slate-800 rounded-xl flex flex-col gap-4">
				<div class="text-emerald-400 text-2xl font-bold" data-i18n="feat_2_metric">Premium UI</div>
				<h3 class="text-xl font-bold" data-i18n="feat_2_title">Fluid Animations</h3>
				<p class="text-slate-400 text-sm leading-relaxed" data-i18n="feat_2_desc">Interactive 3D models and tailored Tailwind CSS styles without harming performance metrics.</p>
			</div>
			<!-- Feature 3 -->
			<div class="p-8 bg-slate-950 border border-slate-800 rounded-xl flex flex-col gap-4">
				<div class="text-emerald-400 text-2xl font-bold" data-i18n="feat_3_metric">Git CMS</div>
				<h3 class="text-xl font-bold" data-i18n="feat_3_title">Full Autoadministrable</h3>
				<p class="text-slate-400 text-sm leading-relaxed" data-i18n="feat_3_desc">Lightweight headless CMS setup. Your client or team updates content directly via GitHub metadata.</p>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="py-24 bg-slate-950 text-slate-50 px-6 border-t border-slate-900">
		<div class="max-w-3xl mx-auto text-center flex flex-col gap-6">
			<h2 class="text-3xl md:text-5xl font-black tracking-tight" data-i18n="contact_heading">Ready to Elevate Your Performance?</h2>
			<p class="text-slate-400 text-lg" data-i18n="contact_subheading">
				Let's deploy a tailored MVP for your team. Fixed price. 50% upfront. Delivered in days.
			</p>
			<div class="mt-8">
				<form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
					<input type="email" placeholder="Enter your business email" required class="px-4 py-3 bg-slate-900 border border-slate-800 rounded-lg focus:outline-none focus:border-emerald-500 flex-grow text-slate-100" id="contact-email" />
					<button type="submit" class="px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold rounded-lg transition-all whitespace-nowrap" data-i18n="contact_btn">
						Get Started
					</button>
				</form>
			</div>
		</div>
	</section>
</Layout>

<!-- Script de traducción -->
<script define:vars={{ translations }} is:inline>
	function updateLanguage(lang) {
		document.querySelectorAll('[data-i18n]').forEach((element) => {
			const key = element.getAttribute('data-i18n');
			if (key && translations[lang] && translations[lang][key]) {
				element.textContent = translations[lang][key];
			}
		});

		const emailInput = document.getElementById('contact-email');
		if (emailInput && translations[lang] && translations[lang].contact_placeholder) {
			emailInput.placeholder = translations[lang].contact_placeholder;
		}

		const btnEn = document.getElementById('btn-en');
		const btnEs = document.getElementById('btn-es');
		
		if (btnEn && btnEs) {
			if (lang === 'en') {
				btnEn.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer bg-emerald-500 text-slate-950 select-none";
				btnEs.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer text-slate-400 hover:text-white select-none";
			} else {
				btnEs.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer bg-emerald-500 text-slate-950 select-none";
				btnEn.className = "text-xs font-bold px-2.5 py-1 rounded-full transition-all cursor-pointer text-slate-400 hover:text-white select-none";
			}
		}

		localStorage.setItem('preferred-lang', lang);
	}

	const savedLang = localStorage.getItem('preferred-lang') || 'en';
	updateLanguage(savedLang);

	document.getElementById('btn-en')?.addEventListener('click', () => updateLanguage('en'));
	document.getElementById('btn-es')?.addEventListener('click', () => updateLanguage('es'));
</script>
